            "mimeType": "application/x-javascript",
            "size": 144,
            "text": "function EmptyHighlighter()\r\n{\r\n}\r\n\r\nEmptyHighlighter.prototype.highlightTokens = function( text )\r\n{\r\n    return escapeHtmlSymbols(text);\r\n};\r\n"
