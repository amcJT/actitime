          ],
          "headersSize": 0
        },
        "response": {
          "status": 200,
          "statusText": "OK",
          "httpVersion": "HTTP/1.1",
          "headers": [
            {
              "name": "Date",
              "value": "Wed, 03 Jun 2026 14:08:43 GMT"
            },
            {
              "name": "Server",
              "value": "Jetty/5.1.4 (Windows NT (unknown)/6.2 x86 java/1.5.0_22"
            },
            {
              "name": "Content-Type",
              "value": "application/x-javascript"
            },
            {
              "name": "Last-Modified",
              "value": "Tue, 14 May 2013 23:14:38 GMT"
            },
            {
              "name": "Cache-Control",
              "value": "public"
            },
            {
              "name": "Expires",
              "value": "Sat, 31 May 2036 14:08:43 GMT"
            },
            {
              "name": "Content-Length",
              "value": "1009"
            },
            {
              "name": "Accept-Ranges",
              "value": "bytes"
            }
          ],
          "cookies": [],
          "content": {
            "mimeType": "application/x-javascript",
            "size": 1009,
            "text": "/**\r\n * Object for key down handler manipulating.\r\n */\r\nfunction KeyDownHandler()\r\n{\r\n}\r\n\r\n/**\r\n * Sets key down handler to the document, saves old handler.\r\n * @param userFunction\r\n */\r\nKeyDownHandler.setOnKeyDownHandler = function(userFunction)\r\n{\r\n    if ( !this.oldDocumentKeydownHandler )\r\n        this.oldDocumentKeydownHandler = new Array();\r\n    this.oldDocumentKeydownHandler.push( document.onkeydown );\r\n\r\n    document.onkeydown = function(event)\r\n    {\r\n        userFunction(event);\r\n    }\r\n}\r\n\r\n/**\r\n * Restores key down handler saved by KeyDownHandler.setOnKeyDownHandler.\r\n */\r\nKeyDownHandler.restoreOnKeyDownHandler = function()\r\n{\r\n    var oldHandler;\r\n    if ( this.oldDocumentKeydownHandler && (oldHandler = this.oldDocumentKeydownHandler.pop()) )\r\n        document.onkeydown = oldHandler;\r\n    else\r\n        document.onkeydown = null;  // We assign null to onkeydown if old handler was undefined,\r\n                                    // because assigning undefined value fails under IE. \r\n}"
          },
          "redirectURL": "",
          "headersSize": 0,
          "bodySize": 0
        },
        "cache": {},
        "timings": {},
        "time": 0,
        "pageref": "page_2"
